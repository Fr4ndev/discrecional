import asyncio
import json
import logging
import sys
from datetime import datetime, timezone
from pathlib import Path

import numpy as np
import pandas as pd

# ── Bootstrap sys.path so we can import from ccxtv2 root ──────────
_ROOT = Path(__file__).parent.parent.parent  # ccxtv2/
sys.path.insert(0, str(_ROOT))

from sema4ai.actions import action

from strategies.funding_fees import FundingFeesEngine
from strategies.funding_monitor import FundingMonitorEngine

